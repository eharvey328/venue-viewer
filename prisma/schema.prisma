generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Venue {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  locality  String?
  country   String?
  lat       Float?
  lng       Float?
  sleeps          Int?
  googleMapsUrl   String?
  googlePlaceId   String?
  instagramUrl    String?
  photoUrl        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  links     VenueLink[]
  photos    VenuePhoto[]
}

model VenueLink {
  id            Int      @id @default(autoincrement())
  venueId       Int
  url           String
  ogTitle       String?
  ogDescription String?
  ogImage       String?
  createdAt     DateTime @default(now())
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model VenuePhoto {
  id        Int      @id @default(autoincrement())
  venueId   Int
  url       String
  caption   String?
  createdAt DateTime @default(now())
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}
