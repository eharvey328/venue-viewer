generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Venue {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  locality  String?
  country   String?
  lat       Float?
  lng       Float?
  sleeps          Int?
  googleMapsUrl   String?
  googlePlaceId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
